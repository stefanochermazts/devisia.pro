---
import { getHreflangPaths, switchLocalePath } from '../lib/localePath';
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/components.css';
import '../styles/utilities.css';
import '../styles/site.css';
import '@fontsource-variable/lexend/wght.css';
import '@fontsource-variable/manrope/wght.css';
import '@fontsource-variable/bitter/wght.css';
import lexendLatinWoff2 from '@fontsource-variable/lexend/files/lexend-latin-wght-normal.woff2';
import manropeLatinWoff2 from '@fontsource-variable/manrope/files/manrope-latin-wght-normal.woff2';
import bitterLatinWoff2 from '@fontsource-variable/bitter/files/bitter-latin-wght-normal.woff2';
import { t } from '../lib/i18n';
import {
  organizationJsonLd,
  websiteJsonLd,
  webPageJsonLd,
  type JsonLd,
} from '../lib/seo/structuredData';

export interface Props {
  title: string;
  /** If set, used as the full <title> (skip automatic "| Devisia" suffix). */
  documentTitle?: string;
  description?: string;
  heroImage?: string;
  canonical?: string;
  lang?: 'it' | 'en';
  structuredData?: JsonLd | JsonLd[];
  languageSwitchHref?: string;
  /** When false, main is full width (sections add their own .ds-container). */
  containMain?: boolean;
}

const {
  title,
  documentTitle,
  description,
  heroImage,
  canonical,
  lang = 'it',
  structuredData,
  languageSwitchHref: customLanguageSwitchHref,
  containMain = true,
} = Astro.props;

const siteName = 'Devisia';
const homeTitleSuffix =
  lang === 'en'
    ? 'Custom software, governed AI and operational compliance'
    : 'Sviluppo software su misura, AI governata e compliance operativa';
const fullTitle =
  documentTitle ??
  (title === 'Home' ? `${siteName} · ${homeTitleSuffix}` : `${title} | ${siteName}`);

const normalizePath = (p: string) => {
  const withoutTrailing = p.length > 1 ? p.replace(/\/+$/, '') : p;
  return withoutTrailing || '/';
};

const canonicalPath = canonical || normalizePath(Astro.url.pathname);
const canonicalURL = new URL(canonicalPath, Astro.site);

const defaultDescription =
  lang === 'en'
    ? 'Devisia is a software development company for custom software, governed AI and operational compliance where evidence, auditability and solid architecture matter.'
    : 'Devisia è una società sviluppo software per software su misura, AI governata e compliance operativa dove contano evidenze, auditabilità e architettura solida.';

const metaDescription = description ?? defaultDescription;

const localePrefix = lang === 'en' ? '/en' : '';
const href = (path: string) => (localePrefix ? `${localePrefix}${path}` : path);
const homeHref = localePrefix || '/';

const pathName = canonicalURL.pathname;

const hreflang = getHreflangPaths(normalizePath(pathName));
const itPathHref = hreflang.itPath;
const enPathHref = hreflang.enPath;

const defaultLanguageSwitch = (): string => {
  const p = normalizePath(pathName);
  const mapped = switchLocalePath(p, lang);
  if (mapped) return mapped;
  if (lang === 'en') {
    if (p === '/en') return '/';
    return p.replace(/^\/en(?=\/|$)/, '') || '/';
  }
  if (p === '/') return '/en';
  return `/en${p}`;
};

const languageSwitchHref = customLanguageSwitchHref || defaultLanguageSwitch();
const languageSwitchAria = lang === 'en' ? 'Switch to Italian' : "Passa all'inglese";

const currentPath = normalizePath(pathName);

const isNavItemActive = (itemPath: string) => {
  const p = currentPath;
  const target = itemPath;
  if (target === '/' || target === '/en') return p === '/' || p === '/en';
  return p === target || p.startsWith(`${target}/`);
};

/** Primary navigation (visible in header) */
const navItems =
  lang === 'en'
    ? [
        { path: '/en/what-we-do', label: 'What we do' },
        { path: '/en/method', label: 'Method' },
        { path: '/en/products', label: 'Products' },
        { path: '/en/blog', label: 'Insights' },
      ]
    : [
        { path: '/cosa-facciamo', label: 'Cosa facciamo' },
        { path: '/metodo', label: 'Metodo' },
        { path: '/prodotti', label: 'Prodotti' },
        { path: '/blog', label: 'Approfondimenti' },
      ];

const contactNavPath = lang === 'en' ? '/en/contact' : '/contatti';
const contactNavLabel = lang === 'en' ? 'Contact' : 'Contatti';
const footerNavItems = [...navItems, { path: contactNavPath, label: contactNavLabel }];

const themeToggleLabel = lang === 'en' ? 'Toggle theme' : 'Cambia tema';
const skipLinkLabel = lang === 'en' ? 'Skip to content' : 'Vai al contenuto';
const footerContent =
  lang === 'en'
    ? {
        tagline: 'Technology partner for products, systems and AI initiatives that must stay governable.',
        quickLinks: 'Quick Links',
        connect: 'Connect',
      }
    : {
        tagline: 'Partner tecnologico per prodotti, sistemi e iniziative AI che devono restare governabili.',
        quickLinks: 'Link utili',
        connect: 'Contatti',
      };

const stickyCtaLabel = lang === 'en' ? 'Share your context' : 'Raccontaci il contesto';
const stickyCtaAria = lang === 'en' ? 'Contact Devisia' : 'Contatta Devisia';

const site = Astro.site ?? new URL('https://devisia.pro');
const pageUrl = canonicalURL.toString();

const baseStructuredData: JsonLd[] = [
  organizationJsonLd(site),
  websiteJsonLd(site, lang),
  webPageJsonLd({
    site,
    lang,
    url: pageUrl,
    name: fullTitle,
    description: metaDescription,
  }),
];

const extraStructuredData: JsonLd[] = Array.isArray(structuredData)
  ? (structuredData as JsonLd[])
  : structuredData
    ? ([structuredData] as JsonLd[])
    : [];

const cookiebotId = import.meta.env.PUBLIC_COOKIEBOT_ID || '';
const gtmId = import.meta.env.PUBLIC_GTM_ID || 'GTM-N7JP6BWG';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/favicon-light.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" href="/images/favicon-dark.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/images/favicon-light.png" />
    <link rel="preload" href={bitterLatinWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={manropeLatinWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={lexendLatinWoff2} as="font" type="font/woff2" crossorigin />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content={siteName} />
    {heroImage && <meta property="og:image" content={new URL(heroImage, Astro.site)} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={metaDescription} />
    {heroImage && <meta property="twitter:image" content={new URL(heroImage, Astro.site)} />}

    <!-- i18n alternates -->
    <link rel="alternate" hreflang="it" href={new URL(itPathHref, site)} />
    <link rel="alternate" hreflang="en" href={new URL(enPathHref, site)} />
    <link rel="alternate" hreflang="x-default" href={new URL(itPathHref, site)} />

    {
      (baseStructuredData.length || extraStructuredData.length) && (
        <>
          {[...baseStructuredData, ...extraStructuredData].map((item) => (
            <script type="application/ld+json" set:html={JSON.stringify(item)} />
          ))}
        </>
      )
    }

    {
      cookiebotId && (
        <>
          <!-- Cookiebot CMP (loads early so banner shows immediately) -->
          <script
            id="Cookiebot"
            src="https://consent.cookiebot.com/uc.js"
            data-cbid={cookiebotId}
            data-blockingmode="auto"
            type="text/javascript"
          ></script>
        </>
      )
    }

    <script is:inline>
      (() => {
        try {
          const key = 'ds-theme';
          const saved = localStorage.getItem(key);
          if (saved === 'dark' || saved === 'light') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch {
          /* noop */
        }
      })();
    </script>
    <slot name="head" />
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a class="skip-link" href="#main">{skipLinkLabel}</a>
    <!-- Header / Navigation -->
    <header class="site-header" data-scrolled="false">
      <nav class="nav-container ds-container" aria-label="Primary">
        <div class="nav-brand">
          <a href={homeHref} class="logo" aria-label="DEVISIA">
            <img 
              class="logo-img logo-img--word logo-img--light" 
              src="/images/logo-light.png" 
              alt="" 
              width="280"
              height="56"
              decoding="async"
              fetchpriority="high"
            />
            <img 
              class="logo-img logo-img--word logo-img--dark" 
              src="/images/logo-dark.png" 
              alt="" 
              width="280"
              height="56"
              decoding="async"
              fetchpriority="high"
            />
          </a>
          {/* Inline language switcher: lives next to the wordmark, where the
              user expects it. Removed from the primary nav so the menu can
              stay around 6 items. */}
          <a
            class="brand-lang"
            href={languageSwitchHref}
            aria-label={languageSwitchAria}
            title={languageSwitchAria}
            hreflang={lang === 'en' ? 'it' : 'en'}
            data-lang-switch
          >
            <span class="brand-lang__current">{lang.toUpperCase()}</span>
            <span class="brand-lang__sep" aria-hidden="true">·</span>
            <span class="brand-lang__alt">{lang === 'en' ? 'IT' : 'EN'}</span>
          </a>
        </div>

        <button
          type="button"
          class="ds-btn nav-toggle"
          data-variant="ghost"
          data-size="sm"
          aria-label={lang === 'en' ? 'Open menu' : 'Apri menu'}
          aria-controls="primary-nav"
          aria-expanded="false"
          data-nav-toggle
        >
          <svg
            class="nav-toggle__icon nav-toggle__icon--open"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg
            class="nav-toggle__icon nav-toggle__icon--close"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
          <span class="nav-toggle__label">Menu</span>
        </button>

        <ul id="primary-nav" class="nav-menu nav-menu--site" data-nav-menu>
          {navItems.map((item) => (
            <li>
              <a
                href={item.path}
                class="nav-link"
                aria-current={isNavItemActive(item.path) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a
              href={contactNavPath}
              class="nav-link nav-link-cta"
              aria-current={isNavItemActive(contactNavPath) ? 'page' : undefined}
            >
              {contactNavLabel}
            </a>
          </li>
        </ul>
      </nav>
    </header>

    <!-- Main Content -->
    <main id="main" class:list={['main-content', containMain && 'ds-container']}>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-container ds-container">
        <div class="footer-content">
          <div class="footer-section">
            <h3>Devisia</h3>
            <p>
              {footerContent.tagline}
            </p>
          </div>

          <div class="footer-section">
            <h4>{footerContent.quickLinks}</h4>
            <ul class="footer-links">
              {footerNavItems.map((item) => (
                <li>
                  <a href={item.path}>{item.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <div class="footer-section">
            <h4>{footerContent.connect}</h4>
            <ul class="footer-links">
              <li><a href="mailto:info@devisia.it">info@devisia.it</a></li>
              <li>
                <a href="https://www.linkedin.com/company/devisia-pro/" target="_blank" rel="noopener noreferrer"
                  >LinkedIn</a>
              </li>
            </ul>
          </div>
        </div>

        <div class="footer-bottom">
          <div class="footer-bottom__legal">
            <p>&copy; {new Date().getFullYear()} Devisia s.r.l. - Riva Tommaso Gulli 12 - 34123 - Trieste</p>
            <p>P.IVA: 01443020324 - PEC: devisia@namirialpec.it - REA: TS - 217091</p>
            <p><a href={href('/privacy')}>{t('policyLink', lang)}</a></p>
          </div>
          {/* Theme toggle moved out of the primary nav to slim the header.
              It lives quietly in the footer, where utility controls belong. */}
          <button
            type="button"
            class="ds-btn footer-theme-toggle"
            data-variant="ghost"
            data-size="sm"
            data-theme-toggle
            aria-label={themeToggleLabel}
            title={themeToggleLabel}
          >
            <svg
              class="theme-icon theme-icon--light"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg
              class="theme-icon theme-icon--dark"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <span class="footer-theme-toggle__label">{themeToggleLabel}</span>
          </button>
        </div>
      </div>
    </footer>

    <!-- Mobile sticky CTA: only renders on narrow viewports and only after
         the user has scrolled past the hero. Hidden by default, revealed via
         data-visible attribute set by the script below. Critical-path action
         for the dominant mobile-traffic persona. -->
    <a
      class="mobile-sticky-cta"
      href={contactNavPath}
      data-mobile-sticky-cta
      data-visible="false"
      aria-label={stickyCtaAria}
    >
      <span class="mobile-sticky-cta__label">{stickyCtaLabel}</span>
      <span class="mobile-sticky-cta__arrow" aria-hidden="true">→</span>
    </a>

    <script is:inline>
      (() => {
        const key = 'ds-theme';
        const root = document.documentElement;
        const btn = document.querySelector('[data-theme-toggle]');
        if (!btn) return;

        const get = () => root.getAttribute('data-theme');
        const set = (t) => {
          if (!t) root.removeAttribute('data-theme');
          else root.setAttribute('data-theme', t);
        };

        btn.addEventListener('click', () => {
          const current = get();
          const next = current === 'dark' ? 'light' : 'dark';
          set(next);
          try {
            localStorage.setItem(key, next);
          } catch {
            /* noop */
          }
        });
      })();
    </script>

    <script is:inline>
      (() => {
        const header = document.querySelector('.site-header');
        if (!header) return;

        let ticking = false;
        const update = () => {
          const scrolled = window.scrollY > 12;
          header.setAttribute('data-scrolled', String(scrolled));
          ticking = false;
        };

        const onScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        };

        update();
        window.addEventListener('scroll', onScroll, { passive: true });
      })();
    </script>

    <script is:inline>
      (() => {
        const btn = document.querySelector('[data-nav-toggle]');
        const menu = document.querySelector('[data-nav-menu]');
        if (!btn || !menu) return;

        const setOpen = (open) => {
          btn.setAttribute('aria-expanded', String(open));
          btn.setAttribute('aria-label', open ? (document.documentElement.lang === 'en' ? 'Close menu' : 'Chiudi menu') : (document.documentElement.lang === 'en' ? 'Open menu' : 'Apri menu'));
          menu.toggleAttribute('data-open', open);
        };

        setOpen(false);

        btn.addEventListener('click', () => {
          const open = btn.getAttribute('aria-expanded') === 'true';
          setOpen(!open);
        });

        menu.addEventListener('click', (e) => {
          const target = e.target;
          if (target && target.tagName === 'A') setOpen(false);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });
      })();
    </script>

    <script is:inline>
      // Mobile sticky CTA: reveal once the user has scrolled past ~60% of the
      // viewport height. We don't show it immediately because it would compete
      // with the hero's primary actions. We hide it again near the page bottom
      // so it doesn't overlap the footer's contact link.
      (() => {
        const cta = document.querySelector('[data-mobile-sticky-cta]');
        if (!cta) return;

        let ticking = false;
        const threshold = () => Math.max(window.innerHeight * 0.6, 480);
        const nearBottom = () => {
          const remaining = document.documentElement.scrollHeight - (window.scrollY + window.innerHeight);
          return remaining < 320;
        };

        const update = () => {
          const visible = window.scrollY > threshold() && !nearBottom();
          cta.setAttribute('data-visible', String(visible));
          ticking = false;
        };

        const onScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        };

        update();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
      })();
    </script>

    <script is:inline define:vars={{ gtmId }}>
      (() => {
        const id = gtmId;
        if (!id) return;

        let loaded = false;
        const alreadyInjected = () =>
          Boolean(document.querySelector('script[data-provider="gtm"][data-id="' + id + '"]'));

        const inject = () => {
          if (loaded || alreadyInjected()) return;
          loaded = true;

          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

          const s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtm.js?id=' + encodeURIComponent(id);
          s.dataset.provider = 'gtm';
          s.dataset.id = id;
          document.head.appendChild(s);
        };

        const loadWhenIdle = () => {
          if ('requestIdleCallback' in window) {
            // @ts-expect-error requestIdleCallback may not be in typings depending on TS lib config
            window.requestIdleCallback(inject, { timeout: 2000 });
          } else {
            setTimeout(inject, 0);
          }
        };

        const hasConsent = () => {
          try {
            // @ts-expect-error Cookiebot is a global injected by the CMP script
            const c = window.Cookiebot && window.Cookiebot.consent;
            return Boolean(c && (c.statistics || c.marketing));
          } catch {
            return false;
          }
        };

        const onConsentReady = () => {
          if (hasConsent()) loadWhenIdle();
        };

        window.addEventListener('CookiebotOnConsentReady', onConsentReady);
        window.addEventListener('CookiebotOnAccept', onConsentReady);

        onConsentReady();
      })();
    </script>
</body>
</html>
