---
import { Image } from 'astro:assets';
import Button from './ui/Button.astro';

export interface Props {
  lang?: 'it' | 'en';
  title: string;
  subtitle?: string | null;
  image?: string | null;
  fallbackImage?: string | null;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  lang = 'it',
  title,
  subtitle,
  image,
  fallbackImage,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;

const showActions =
  Boolean(primaryHref && primaryLabel) || Boolean(secondaryHref && secondaryLabel);
const sectionLabel = lang === 'en' ? 'Page opening' : 'Apertura pagina';
---

<section class="page-hero" aria-label={sectionLabel} style="container-type: inline-size">
  <section class="page-hero__copy ds-stack" data-gap="sm">
    <p class="page-hero__eyebrow" aria-hidden="true">Devisia</p>
    <h1 class="page-hero__title">{title}</h1>
    {
      subtitle && (
        <p class="page-hero__subtitle">
          {subtitle}
        </p>
      )
    }

    {
      showActions && (
        <section class="ds-cluster page-hero__actions">
          {primaryHref && primaryLabel && (
            <Button href={primaryHref} variant="primary">
              {primaryLabel}
            </Button>
          )}
          {secondaryHref && secondaryLabel && (
            <Button href={secondaryHref} variant="secondary">
              {secondaryLabel}
            </Button>
          )}
        </section>
      )
    }
  </section>

  <section class="page-hero__media-wrap">
    <section class="page-hero__media">
      {
        image || fallbackImage ? (
          <Image 
            class="page-hero__image ds-img-color"
            src={(image ?? fallbackImage) as string} 
            alt="" 
            loading="eager" 
            decoding="async" 
            fetchpriority="high"
            width={800}
            height={450}
            widths={[320, 480, 540, 640, 800]}
            sizes="(max-width: 52rem) 92vw, 42vw"
          />
        ) : (
          <section class="page-hero__placeholder">
            <p class="ds-muted" style="margin: 0">
              {lang === 'en'
                ? 'Hero image placeholder. Add an image in the CMS to customize this area.'
                : "Segnaposto immagine hero. Aggiungi un'immagine dal CMS per personalizzare questa area."}
            </p>
          </section>
        )
      }
    </section>
  </section>
</section>

<style>
  .page-hero {
    display: grid;
    gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    align-items: end;
    margin-bottom: var(--ds-space-9);
  }

  .page-hero__copy {
    max-width: 40rem;
  }

  .page-hero__eyebrow {
    margin: 0;
    font-size: var(--ds-text-xs);
    font-weight: 700;
    letter-spacing: var(--ds-tracking-wordmark);
    text-transform: uppercase;
    color: var(--ds-color-accent);
  }

  .page-hero__title {
    margin: 0;
    max-width: 11ch;
    font-family: var(--ds-font-heading);
    font-size: var(--ds-text-4xl);
    font-weight: 760;
    line-height: 1.08;
    letter-spacing: -0.028em;
    text-wrap: balance;
  }

  .page-hero__subtitle {
    margin: 0;
    max-width: 58ch;
    font-size: var(--ds-text-md);
    line-height: var(--ds-leading-relaxed);
    color: var(--ds-color-text);
  }

  .page-hero__actions {
    margin-top: var(--ds-space-4);
  }

  .page-hero__media-wrap {
    display: flex;
    justify-content: flex-end;
  }

  .page-hero__media,
  .page-hero__placeholder {
    width: min(100%, 38rem);
  }

  .page-hero__image,
  .page-hero__placeholder {
    width: 100%;
    min-height: 100%;
    border-radius: calc(var(--ds-radius-3) + 0.25rem);
    border: var(--ds-border-1) solid color-mix(in srgb, var(--ds-color-primary) 18%, var(--ds-color-border));
    box-shadow: var(--ds-shadow-1);
    background: color-mix(in srgb, var(--ds-color-surface) 84%, var(--ds-color-bg));
    overflow: hidden;
  }

  .page-hero__image {
    display: block;
    aspect-ratio: 5 / 4;
    object-fit: cover;
  }

  .page-hero__placeholder {
    display: grid;
    place-items: center;
    padding: var(--ds-space-6);
  }

  @container (min-width: 52rem) {
    .page-hero {
      grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
    }
  }
</style>
