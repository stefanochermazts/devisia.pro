<section class="ds-card" data-ai-structure-output hidden>
  <section class="ds-card__body" style="display:grid; gap: var(--ds-space-4);">
    <section>
      <h2 style="margin:0 0 var(--ds-space-2); font-size: var(--ds-text-lg);">1) System Overview</h2>
      <section class="ds-ai-structure__flow">
        <p
          data-artifact-system-overview
          style="margin:0; color: var(--ds-color-text); line-height: var(--ds-leading-relaxed); font-size: var(--ds-text-md); width: 100%; max-width: none;"
        ></p>
      </section>
    </section>

    <section>
      <h2 style="margin:0 0 var(--ds-space-2); font-size: var(--ds-text-lg);">2) Core Domain Model</h2>
      <ul data-artifact-domain-model style="margin:0; padding-left: 1.1rem; display:grid; gap: 0.35rem;"></ul>
    </section>

    <section>
      <h2 style="margin:0 0 var(--ds-space-2); font-size: var(--ds-text-lg);">3) Key Flows</h2>
      <section data-artifact-flows style="display:grid; gap: var(--ds-space-2);"></section>
    </section>

    <section>
      <h2 style="margin:0 0 var(--ds-space-2); font-size: var(--ds-text-lg);">4) Critical Considerations</h2>
      <section style="display:grid; gap: var(--ds-space-3);">
        <section>
          <section style="font-weight:700; margin-bottom: 0.35rem;">Technical</section>
          <ul data-artifact-considerations-technical style="margin:0; padding-left: 1.1rem; display:grid; gap: 0.35rem;"></ul>
        </section>
        <section>
          <section style="font-weight:700; margin-bottom: 0.35rem;">Privacy &amp; Data</section>
          <ul data-artifact-considerations-privacy style="margin:0; padding-left: 1.1rem; display:grid; gap: 0.35rem;"></ul>
        </section>
        <section>
          <section style="font-weight:700; margin-bottom: 0.35rem;">Architectural</section>
          <ul data-artifact-considerations-architectural style="margin:0; padding-left: 1.1rem; display:grid; gap: 0.35rem;"></ul>
        </section>
      </section>
    </section>

    <section data-ai-structure-after-text style="margin:0;" hidden>
      <p style="margin:0 0 0.35rem; color: var(--ds-color-text);">
        This output is an initial technical structure: domain concepts, flows and critical points.
      </p>
      <p style="margin:0; color: var(--ds-color-text-muted); font-size: var(--ds-text-sm);">
        It is not a complete specification or an implementation. Use it to align boundaries and risks before the next step.
      </p>
    </section>
    <p
      class="ds-muted"
      data-ai-structure-model-line
      hidden
      style="margin: 0; font-size: var(--ds-text-xs);"
    >
      Model: <span data-ai-structure-model></span>
    </p>

    <section style="display:flex; gap: var(--ds-space-2); flex-wrap: wrap;">
      <button class="ds-btn" data-variant="primary" type="button" data-ai-structure-open-modal hidden>
        Let's review it together
      </button>
      <button class="ds-btn" data-variant="secondary" type="button" data-ai-structure-regenerate hidden>
        Regenerate
      </button>
    </section>
  </section>
</section>
