---
const partnerId = import.meta.env.PUBLIC_LINKEDIN_PARTNER_ID || '10089849';
---

<script is:inline define:vars={{ partnerId }}>
  (() => {
    const pid = partnerId;
    if (!pid) return;

    let loaded = false;
    const alreadyInjected = () =>
      Boolean(document.querySelector('script[data-provider="linkedin-insight"][data-id="' + pid + '"]'));

    const inject = () => {
      if (loaded || alreadyInjected()) return;
      loaded = true;

      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      if (!window._linkedin_data_partner_ids.includes(pid)) {
        window._linkedin_data_partner_ids.push(pid);
      }

      (function (l) {
        if (!l) {
          window.lintrk = function (a, b) {
            window.lintrk.q.push([a, b]);
          };
          window.lintrk.q = [];
        }
        var s = document.getElementsByTagName('script')[0];
        var b = document.createElement('script');
        b.type = 'text/javascript';
        b.async = true;
        b.src = 'https://snap.licdn.com/li.lms-analytics/insight.min.js';
        b.dataset.provider = 'linkedin-insight';
        b.dataset.id = pid;
        s.parentNode.insertBefore(b, s);
      })(window.lintrk);
    };

    const loadWhenIdle = () => {
      if ('requestIdleCallback' in window) {
        // @ts-expect-error requestIdleCallback may not be in typings depending on TS lib config
        window.requestIdleCallback(inject, { timeout: 2000 });
      } else {
        setTimeout(inject, 0);
      }
    };

    const hasMarketingConsent = () => {
      try {
        // @ts-expect-error Cookiebot is a global injected by the CMP script
        const c = window.Cookiebot && window.Cookiebot.consent;
        return Boolean(c && c.marketing);
      } catch {
        return false;
      }
    };

    const onConsentReady = () => {
      if (hasMarketingConsent()) loadWhenIdle();
    };

    window.addEventListener('CookiebotOnConsentReady', onConsentReady);
    window.addEventListener('CookiebotOnAccept', onConsentReady);

    onConsentReady();
  })();
</script>
<noscript>
  <img
    height="1"
    width="1"
    style="display:none;"
    alt=""
    src={`https://px.ads.linkedin.com/collect/?pid=${partnerId}&fmt=gif`}
  />
</noscript>
