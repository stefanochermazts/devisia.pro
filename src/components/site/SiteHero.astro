---
export interface Props {
  title: string;
  lede: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel: string;
  secondaryHref: string;
}
const { title, lede, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---

<section class="site-hero site-hero--bleed" data-hero>
  <section class="ds-container site-hero__inner">
    <section class="site-hero__grid">
      <section class="site-hero__copy">
        <h1 class="site-hero__title">{title}</h1>
        <p class="site-hero__lede">{lede}</p>
        <section class="site-hero__actions">
          <a class="ds-btn" data-variant="primary" data-size="lg" href={primaryHref}>
            {primaryLabel}
          </a>
          <a class="ds-link" data-variant="muted" href={secondaryHref}>
            {secondaryLabel} <span aria-hidden="true">→</span>
          </a>
        </section>
      </section>
      <slot name="visual" />
    </section>
  </section>
</section>
