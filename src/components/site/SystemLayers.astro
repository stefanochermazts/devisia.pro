---
export interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;
const isEn = lang === 'en';
---

<section class="site-layers" aria-hidden="true">
  <section class="site-layers__frame">
    <section class="site-layers__axis site-layers__axis--x"></section>
    <section class="site-layers__axis site-layers__axis--y"></section>
    <section class="site-layers__node site-layers__node--process">01</section>
    <section class="site-layers__node site-layers__node--data">02</section>
    <section class="site-layers__node site-layers__node--system">03</section>
    <section class="site-layers__node site-layers__node--proof">
      {isEn ? 'proof' : 'prove'}
    </section>
  </section>
  {
    isEn ? (
      <>
        <section class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Process, roles, exceptions, decisions</span>
        </section>
        <section class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Data, ownership, policies, evidence</span>
        </section>
        <section class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Software, automation, models, operations</span>
        </section>
      </>
    ) : (
      <>
        <section class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Processo, ruoli, eccezioni, decisioni</span>
        </section>
        <section class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Dati, responsabilità, policy, evidenze</span>
        </section>
        <section class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Software, automazione, modelli, operatività</span>
        </section>
      </>
    )
  }
</section>
