---
export interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;
const isEn = lang === 'en';
---

<div class="site-layers" aria-hidden="true">
  <div class="site-layers__frame">
    <div class="site-layers__axis site-layers__axis--x"></div>
    <div class="site-layers__axis site-layers__axis--y"></div>
    <div class="site-layers__node site-layers__node--process">01</div>
    <div class="site-layers__node site-layers__node--data">02</div>
    <div class="site-layers__node site-layers__node--system">03</div>
    <div class="site-layers__node site-layers__node--proof">
      {isEn ? 'proof' : 'prove'}
    </div>
  </div>
  {
    isEn ? (
      <>
        <div class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Process, roles, exceptions, decisions</span>
        </div>
        <div class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Data, ownership, policies, evidence</span>
        </div>
        <div class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Software, automation, models, operations</span>
        </div>
      </>
    ) : (
      <>
        <div class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Processo, ruoli, eccezioni, decisioni</span>
        </div>
        <div class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Dati, responsabilità, policy, evidenze</span>
        </div>
        <div class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Software, automazione, modelli, operatività</span>
        </div>
      </>
    )
  }
</div>
