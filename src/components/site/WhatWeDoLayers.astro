---
/**
 * "Cosa facciamo / What we do" diagram: same visual language as home SystemLayers,
 * different copy synthesising build, integrate, govern, evidence.
 */
export interface Props {
  lang: 'it' | 'en';
}
const { lang } = Astro.props;
const isEn = lang === 'en';
---

<section class="site-layers" aria-hidden="true">
  <section class="site-layers__frame site-layers__frame--whatwedo">
    <section class="site-layers__axis site-layers__axis--x"></section>
    <section class="site-layers__axis site-layers__axis--y"></section>
    <section class="site-layers__node site-layers__node--process">01</section>
    <section class="site-layers__node site-layers__node--data">02</section>
    <section class="site-layers__node site-layers__node--system">03</section>
    <section class="site-layers__node site-layers__node--proof">
      {isEn ? 'proof' : 'prove'}
    </section>
  </section>
  {
    isEn ? (
      <>
        <section class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Build: applications, platforms, durable services</span>
        </section>
        <section class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Integrate: data, APIs, contracts with what you run</span>
        </section>
        <section class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Govern: AI, controls, operations and verifiable evidence</span>
        </section>
      </>
    ) : (
      <>
        <section class="site-layers__row site-layers__row--process">
          <span class="site-layers__label">01</span>
          <span>Costruire: applicazioni, piattaforme, servizi che reggono nel tempo</span>
        </section>
        <section class="site-layers__row site-layers__row--data">
          <span class="site-layers__label">02</span>
          <span>Integrare: dati, API, contratti con i sistemi esistenti</span>
        </section>
        <section class="site-layers__row site-layers__row--system">
          <span class="site-layers__label">03</span>
          <span>Governare: AI, controlli, operatività ed evidenze verificabili</span>
        </section>
      </>
    )
  }
</section>
