---
/**
 * Bilingual method graph for Metodo / Method pages.
 * Visual is decorative: copy lives in PageIntro and body; SR gets a short summary.
 */
export interface Props {
  lang: 'it' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';

const copy = isEn
  ? {
      summary:
        'Method flow: observe, model, delimit, build, verify, govern, with a feedback loop from govern back to observe.',
      feedback: 'Loop',
    }
  : {
      summary:
        "Flusso del metodo: osservare, modellare, delimitare, costruire, verificare, governare, con feedback verso l'osservazione.",
      feedback: 'Ritorno',
    };

const steps = isEn
  ? [
      { n: '01', label: 'Observe' },
      { n: '02', label: 'Model' },
      { n: '03', label: 'Delimit' },
      { n: '04', label: 'Build' },
      { n: '05', label: 'Verify' },
      { n: '06', label: 'Govern' },
    ]
  : [
      { n: '01', label: 'Osservare' },
      { n: '02', label: 'Modellare' },
      { n: '03', label: 'Delimitare' },
      { n: '04', label: 'Costruire' },
      { n: '05', label: 'Verificare' },
      { n: '06', label: 'Governare' },
    ];
---

<section class="method-graph">
  <p class="sr-only">{copy.summary}</p>
  <section class="method-graph__board">
    <section class="method-graph__flow method-graph__flow--stack" aria-hidden="true">
      {
        steps.map((s, i) => (
          <section class="method-graph__step">
            <section class="method-graph__node">
              <span class="method-graph__num">{s.n}</span>
              <span class="method-graph__label">{s.label}</span>
            </section>
            {i < steps.length - 1 && <span class="method-graph__chev" aria-hidden="true">→</span>}
          </section>
        ))
      }
    </section>
    <p class="method-graph__loop" aria-hidden="true">
      <span class="method-graph__loop-text">{copy.feedback}</span>
    </p>
  </section>
</section>
