---
/**
 * Bilingual method graph for Metodo / Method pages.
 * Visual is decorative: copy lives in PageIntro and body; SR gets a short summary.
 */
export interface Props {
  lang: 'it' | 'en';
}

const { lang } = Astro.props;
const isEn = lang === 'en';

const copy = isEn
  ? {
      summary:
        'Method flow: understand, design, scope, build, verify, evolve, with a feedback loop from evolve back to understand.',
      feedback: 'Loop',
    }
  : {
      summary:
        "Flusso del metodo: capire, progettare, definire, costruire, verificare, evolvere, con ritorno verso l'analisi.",
      feedback: 'Ritorno',
    };

const steps = isEn
  ? [
      { n: '01', label: 'Understand' },
      { n: '02', label: 'Design' },
      { n: '03', label: 'Scope' },
      { n: '04', label: 'Build' },
      { n: '05', label: 'Verify' },
      { n: '06', label: 'Evolve' },
    ]
  : [
      { n: '01', label: 'Capire' },
      { n: '02', label: 'Progettare' },
      { n: '03', label: 'Definire' },
      { n: '04', label: 'Costruire' },
      { n: '05', label: 'Verificare' },
      { n: '06', label: 'Evolvere' },
    ];
---

<section class="method-graph">
  <p class="sr-only">{copy.summary}</p>
  <section class="method-graph__board">
    <section class="method-graph__flow method-graph__flow--stack" aria-hidden="true">
      {
        steps.map((s, i) => (
          <section class="method-graph__step">
            <section class="method-graph__node">
              <span class="method-graph__num">{s.n}</span>
              <span class="method-graph__label">{s.label}</span>
            </section>
            {i < steps.length - 1 && (
              <span class="method-graph__chev" aria-hidden="true">
                →
              </span>
            )}
          </section>
        ))
      }
    </section>
    <p class="method-graph__loop" aria-hidden="true">
      <span class="method-graph__loop-text">{copy.feedback}</span>
    </p>
  </section>
</section>
