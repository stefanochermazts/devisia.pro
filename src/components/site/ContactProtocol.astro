---
import ContactForm from './ContactForm.astro';

interface Copy {
  ariaLabel: string;
  eyebrow: string;
  title: string;
  lede: string;
  status: string[];
  mark: string;
  successTitle: string;
  successText: string;
  protocolTitle: string;
  protocolSteps: Array<{
    code: string;
    title: string;
    text: string;
  }>;
  directTitle: string;
  directText: string;
  phoneLabel: string;
  emailLabel: string;
  briefingTitle: string;
  briefingItems: string[];
  privacyTitle: string;
  privacyText: string;
  checklistText: string;
  checklistLink: string;
}

interface Props {
  lang?: 'it' | 'en';
  isSuccess?: boolean;
}

const { lang = 'it', isSuccess = false } = Astro.props;
const isEnglish = lang === 'en';

const copy: Copy = isEnglish
  ? {
      ariaLabel: 'Contact Devisia',
      eyebrow: 'Let us talk',
      title: 'Tell us what you want to improve.',
      lede: 'Whether it is a digital product, an internal process or an AI use case, we start from goals, constraints and priorities to understand the right next step.',
      status: ['Goal', 'Priorities', 'Reply in 24 business hours'],
      mark: 'CONTACT',
      successTitle: 'Message received.',
      successText:
        'Thank you. We will review your request and reply within 24 business hours with focused questions or a clear next step.',
      protocolTitle: 'How we work after the first contact',
      protocolSteps: [
        {
          code: '01',
          title: 'Understand the request',
          text: 'We read goals, urgency, constraints and people involved before suggesting a direction.',
        },
        {
          code: '02',
          title: 'Frame the work',
          text: 'We separate what can move now from what needs analysis, development or gradual improvement.',
        },
        {
          code: '03',
          title: 'Reply',
          text: 'You receive the most sensible next step: a call, audit, estimate or work plan.',
        },
      ],
      directTitle: 'Direct contact',
      directText:
        'Prefer to speak with a person right away? Email or call us with a short note about the project or problem.',
      phoneLabel: 'Phone',
      emailLabel: 'Email',
      briefingTitle: 'Useful details to include',
      briefingItems: [
        'Business goal or problem to solve',
        'Current situation and tools involved',
        'Timeline, priorities and main constraints',
        'Who will use the solution and who decides',
      ],
      privacyTitle: 'Data and privacy',
      privacyText:
        'Please avoid sensitive data or confidential documents in the form. If examples are useful, we can start from simplified cases and agree how to handle information and access.',
      checklistText: 'Planning an AI project? Use the AI Risk & Privacy Checklist',
      checklistLink: '/en/tools/ai-risk-checklist',
    }
  : {
      ariaLabel: 'Contatta Devisia',
      eyebrow: 'Parliamone',
      title: 'Raccontaci cosa vuoi migliorare.',
      lede: 'Che si tratti di un prodotto digitale, di un processo interno o di un uso dell’AI, partiamo da obiettivi, vincoli e priorità per capire il passo giusto.',
      status: ['Obiettivo', 'Priorità', 'Risposta entro 24 ore lavorative'],
      mark: 'CONTATTO',
      successTitle: 'Messaggio ricevuto.',
      successText:
        'Grazie. Leggiamo la richiesta e ti rispondiamo entro 24 ore lavorative con domande mirate o un primo passo chiaro.',
      protocolTitle: 'Come lavoriamo dopo il primo contatto',
      protocolSteps: [
        {
          code: '01',
          title: 'Capire la richiesta',
          text: 'Leggiamo obiettivi, urgenze, vincoli e persone coinvolte prima di suggerire una direzione.',
        },
        {
          code: '02',
          title: 'Inquadrare il lavoro',
          text: 'Distinguiamo ciò che può partire subito da ciò che richiede analisi, sviluppo o miglioramento progressivo.',
        },
        {
          code: '03',
          title: 'Risposta',
          text: 'Ti proponiamo il passo successivo più sensato: call, audit, stima o piano di lavoro.',
        },
      ],
      directTitle: 'Contatti diretti',
      directText:
        'Preferisci parlare subito con una persona? Scrivici o chiamaci indicando in poche parole il progetto o il problema da affrontare.',
      phoneLabel: 'Telefono',
      emailLabel: 'Email',
      briefingTitle: 'Cosa è utile includere',
      briefingItems: [
        'Obiettivo di business o problema da risolvere',
        'Stato attuale e strumenti coinvolti',
        'Tempi, priorità e vincoli principali',
        'Chi userà la soluzione e chi decide',
      ],
      privacyTitle: 'Dati e privacy',
      privacyText:
        'Nel form evita dati sensibili o documenti riservati. Se servono esempi, possiamo partire da casi semplificati e definire insieme come trattare informazioni e accessi.',
      checklistText: 'Hai un progetto AI? Consulta la checklist rischi e privacy',
      checklistLink: '/tools/ai-risk-checklist',
    };
---

<article class="contact-protocol" aria-label={copy.ariaLabel}>
  {
    isSuccess && (
      <section class="contact-success" role="alert">
        <svg
          class="contact-success__icon"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20 6 9 17l-5-5" />
        </svg>
        <section>
          <h2>{copy.successTitle}</h2>
          <p>{copy.successText}</p>
        </section>
      </section>
    )
  }

  <section class="contact-hero">
    <section class="contact-hero__copy">
      <p class="contact-hero__eyebrow">{copy.eyebrow}</p>
      <h1>{copy.title}</h1>
      <p class="contact-hero__lede">{copy.lede}</p>
      <section
        class="contact-hero__status"
        aria-label={isEnglish ? 'Contact steps' : 'Passaggi del contatto'}
      >
        {copy.status.map((item) => <span>{item}</span>)}
      </section>
    </section>

    <section class="contact-hero__diagram" aria-hidden="true">
      <span class="contact-hero__mark">{copy.mark}</span>
      <span class="contact-hero__axis"></span>
      <span class="contact-hero__node contact-hero__node--context">CTX</span>
      <span class="contact-hero__node contact-hero__node--control">CTRL</span>
      <span class="contact-hero__node contact-hero__node--reply">24H</span>
    </section>
  </section>

  <section class="contact-workbench" aria-labelledby="contact-form-title">
    <section class="contact-workbench__form">
      <ContactForm
        lang={lang}
        headingId="contact-form-title"
        source={isEnglish ? 'contact-en' : 'contact-it'}
        returnTo={isEnglish ? '/en/contact' : '/contatti'}
      />
    </section>

    <aside
      class="contact-workbench__rail"
      aria-label={isEnglish ? 'Contact protocol details' : 'Dettagli del protocollo di contatto'}
    >
      <section class="contact-protocol-steps" aria-labelledby="contact-protocol-title">
        <h2 id="contact-protocol-title">{copy.protocolTitle}</h2>
        <ol>
          {
            copy.protocolSteps.map((step) => (
              <li>
                <span>{step.code}</span>
                <section>
                  <h3>{step.title}</h3>
                  <p>{step.text}</p>
                </section>
              </li>
            ))
          }
        </ol>
      </section>

      <section class="contact-direct" aria-labelledby="contact-direct-title">
        <h2 id="contact-direct-title">{copy.directTitle}</h2>
        <p>{copy.directText}</p>
        <dl>
          <dt>{copy.emailLabel}</dt>
          <dd><a href="mailto:info@devisia.it">info@devisia.it</a></dd>
          <dt>{copy.phoneLabel}</dt>
          <dd><a href="tel:+390409777469">+39 040 977 7469</a></dd>
        </dl>
      </section>

      <section class="contact-brief" aria-labelledby="contact-brief-title">
        <h2 id="contact-brief-title">{copy.briefingTitle}</h2>
        <ul>
          {copy.briefingItems.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="contact-privacy" aria-labelledby="contact-privacy-title">
        <h2 id="contact-privacy-title">{copy.privacyTitle}</h2>
        <p>{copy.privacyText}</p>
        <a href={copy.checklistLink}>{copy.checklistText}</a>
      </section>
    </aside>
  </section>
</article>

<style>
  .contact-protocol {
    position: relative;
    overflow: clip;
    background:
      linear-gradient(
        112deg,
        transparent 0 58%,
        color-mix(in oklch, var(--ds-color-accent) 14%, transparent) 58% 60%,
        transparent 60%
      ),
      linear-gradient(
        90deg,
        color-mix(in oklch, var(--ds-color-accent-2) 10%, transparent) 1px,
        transparent 1px
      ),
      var(--ds-color-bg);
    background-size:
      auto,
      clamp(3rem, 7vw, 6rem) clamp(3rem, 7vw, 6rem),
      auto;
  }

  .contact-hero,
  .contact-workbench,
  .contact-success {
    width: min(100% - 2rem, 76rem);
    margin-inline: auto;
  }

  .contact-hero {
    display: grid;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
    padding-block: clamp(3.25rem, 2rem + 5vw, 6.6rem) clamp(2rem, 4vw, 3.8rem);
  }

  @media (min-width: 58rem) {
    .contact-hero {
      grid-template-columns: minmax(0, 0.98fr) minmax(24rem, 0.72fr);
    }
  }

  .contact-hero__copy {
    position: relative;
    z-index: 1;
  }

  .contact-hero__eyebrow {
    margin: 0 0 var(--ds-space-3);
    color: var(--ds-color-accent);
    font-size: var(--ds-text-xs);
    font-weight: 800;
    letter-spacing: var(--ds-tracking-caps);
    text-transform: uppercase;
  }

  .contact-hero h1 {
    max-width: 11.4ch;
    margin: 0;
    color: var(--ds-color-text);
    font-family: var(--ds-font-display);
    font-size: clamp(3.1rem, 0.9rem + 7.1vw, 6.9rem);
    font-weight: 800;
    letter-spacing: -0.055em;
    line-height: 0.92;
    word-spacing: 0.06em;
    text-wrap: balance;
  }

  .contact-hero__lede {
    max-width: 58ch;
    margin: var(--ds-space-6) 0 0;
    color: var(--ds-color-text-muted);
    font-size: clamp(1.05rem, 0.7vw + 0.95rem, 1.35rem);
    line-height: var(--ds-leading-relaxed);
  }

  .contact-hero__status {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    margin-top: var(--ds-space-6);
    width: fit-content;
    border: 1px solid color-mix(in oklch, var(--ds-color-accent) 36%, var(--ds-color-border));
    background: color-mix(in oklch, var(--ds-color-accent) 26%, var(--ds-color-border));
  }

  .contact-hero__status span {
    padding: 0.78rem 0.95rem;
    background: var(--ds-color-surface);
    color: var(--ds-color-text);
    font-size: var(--ds-text-xs);
    font-weight: 800;
    letter-spacing: var(--ds-tracking-caps);
    text-transform: uppercase;
  }

  .contact-hero__status span:first-child {
    background: var(--ds-color-accent);
    color: color-mix(in oklch, white 95%, var(--ds-color-accent));
  }

  .contact-hero__diagram {
    position: relative;
    min-height: clamp(18rem, 30vw, 26rem);
    border: 1px solid color-mix(in oklch, var(--ds-color-accent) 36%, var(--ds-color-border));
    background:
      linear-gradient(
        135deg,
        color-mix(in oklch, var(--ds-color-hero-tint) 92%, black),
        color-mix(in oklch, var(--ds-color-accent) 20%, var(--ds-color-hero-tint))
      ),
      var(--ds-color-hero-tint);
    color: color-mix(in oklch, white 90%, var(--ds-color-hero-tint));
    box-shadow: 0 2rem 4rem color-mix(in oklch, var(--ds-color-hero-tint) 24%, transparent);
    clip-path: polygon(0 0, 100% 7%, 94% 100%, 5% 92%);
    isolation: isolate;
    overflow: hidden;
  }

  .contact-hero__diagram::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, color-mix(in oklch, white 12%, transparent) 1px, transparent 1px),
      linear-gradient(0deg, color-mix(in oklch, white 10%, transparent) 1px, transparent 1px);
    background-size: 4rem 4rem;
    opacity: 0.5;
  }

  .contact-hero__mark {
    position: absolute;
    inset-inline: -0.2em;
    bottom: -0.16em;
    z-index: -1;
    color: color-mix(in oklch, white 12%, transparent);
    font-family: var(--ds-font-display);
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    letter-spacing: -0.09em;
    line-height: 0.8;
    white-space: nowrap;
  }

  .contact-hero__axis {
    position: absolute;
    left: 18%;
    right: 15%;
    top: 48%;
    height: 2px;
    background: color-mix(in oklch, var(--ds-color-accent) 70%, white);
    transform: rotate(-16deg);
  }

  .contact-hero__node {
    position: absolute;
    display: grid;
    place-items: center;
    width: clamp(4.6rem, 7vw, 6.5rem);
    aspect-ratio: 1;
    border: 1px solid color-mix(in oklch, var(--ds-color-accent) 62%, white);
    background: color-mix(in oklch, var(--ds-color-hero-tint) 78%, black);
    color: color-mix(in oklch, white 92%, var(--ds-color-hero-tint));
    font-size: var(--ds-text-xs);
    font-weight: 900;
    letter-spacing: var(--ds-tracking-caps);
  }

  .contact-hero__node--context {
    left: 14%;
    top: 19%;
  }

  .contact-hero__node--control {
    left: 45%;
    top: 39%;
    width: clamp(5.7rem, 8vw, 7.4rem);
    background: var(--ds-color-accent);
  }

  .contact-hero__node--reply {
    right: 13%;
    bottom: 21%;
  }

  .contact-success {
    display: flex;
    gap: var(--ds-space-4);
    align-items: flex-start;
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    padding: clamp(1.25rem, 2vw, 1.8rem);
    border: 1px solid color-mix(in oklch, var(--ds-color-success) 44%, var(--ds-color-border));
    background: color-mix(in oklch, var(--ds-color-success) 12%, var(--ds-color-surface));
  }

  .contact-success__icon {
    flex: 0 0 auto;
    color: var(--ds-color-success);
  }

  .contact-success h2 {
    margin: 0 0 var(--ds-space-2);
    font-size: var(--ds-text-xl);
  }

  .contact-success p {
    margin: 0;
    color: var(--ds-color-text-muted);
  }

  .contact-workbench {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    padding-block: 0 clamp(4rem, 7vw, 7rem);
  }

  @media (min-width: 64rem) {
    .contact-workbench {
      grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.54fr);
    }
  }

  .contact-workbench__form {
    position: relative;
    padding: clamp(1.4rem, 3vw, 2.6rem);
    border: 1px solid color-mix(in oklch, var(--ds-color-accent) 38%, var(--ds-color-border));
    background: color-mix(in oklch, var(--ds-color-surface) 92%, var(--ds-color-accent));
    box-shadow: 0 2rem 5rem color-mix(in oklch, var(--ds-color-accent) 13%, transparent);
  }

  .contact-workbench__form::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 0.45rem;
    background: var(--ds-color-accent);
  }

  .contact-direct a,
  .contact-privacy a {
    color: var(--ds-color-accent);
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-workbench__rail {
    display: grid;
    gap: 1px;
    border: 1px solid var(--ds-color-border);
    background: var(--ds-color-border);
  }

  .contact-workbench__rail > section {
    padding: clamp(1.1rem, 2vw, 1.45rem);
    background: color-mix(in oklch, var(--ds-color-surface) 95%, var(--ds-color-hero-tint));
  }

  .contact-workbench__rail h2,
  .contact-protocol-steps h3 {
    margin: 0;
    color: var(--ds-color-text);
  }

  .contact-workbench__rail h2 {
    font-size: var(--ds-text-md);
    letter-spacing: -0.02em;
  }

  .contact-protocol-steps ol,
  .contact-brief ul {
    display: grid;
    gap: var(--ds-space-4);
    margin: var(--ds-space-4) 0 0;
    padding: 0;
    list-style: none;
  }

  .contact-protocol-steps li {
    display: grid;
    grid-template-columns: 3.2rem minmax(0, 1fr);
    gap: var(--ds-space-3);
    align-items: start;
  }

  .contact-protocol-steps li > span {
    display: grid;
    place-items: center;
    aspect-ratio: 1;
    border: 1px solid color-mix(in oklch, var(--ds-color-accent) 42%, var(--ds-color-border));
    color: var(--ds-color-accent);
    font-size: var(--ds-text-xs);
    font-weight: 900;
    letter-spacing: var(--ds-tracking-caps);
  }

  .contact-protocol-steps p,
  .contact-direct p,
  .contact-privacy p {
    margin: var(--ds-space-2) 0 0;
    color: var(--ds-color-text-muted);
    font-size: var(--ds-text-sm);
    line-height: var(--ds-leading-relaxed);
  }

  .contact-direct dl {
    display: grid;
    gap: 1px;
    margin: var(--ds-space-4) 0 0;
    background: var(--ds-color-border);
  }

  .contact-direct dt {
    margin: 0;
    padding: 0.85rem 0.85rem 0.2rem;
    background: var(--ds-color-surface);
    color: var(--ds-color-text-muted);
    font-size: var(--ds-text-xs);
    font-weight: 800;
    letter-spacing: var(--ds-tracking-caps);
    text-transform: uppercase;
  }

  .contact-direct dd {
    margin: 0;
    padding: 0 0.85rem 0.85rem;
    background: var(--ds-color-surface);
  }

  .contact-brief li {
    position: relative;
    padding-left: 1.15rem;
    color: var(--ds-color-text-muted);
    font-size: var(--ds-text-sm);
    line-height: var(--ds-leading-relaxed);
  }

  .contact-brief li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 0.42rem;
    height: 0.42rem;
    background: var(--ds-color-accent);
  }

  .contact-privacy a {
    display: inline-block;
    margin-top: var(--ds-space-3);
    font-size: var(--ds-text-sm);
  }

  @media (max-width: 44rem) {
    .contact-hero,
    .contact-workbench,
    .contact-success {
      width: min(100% - 1.25rem, 76rem);
    }

    .contact-hero h1 {
      font-size: clamp(3.15rem, 17vw, 4.8rem);
    }

    .contact-hero__status {
      width: 100%;
    }

    .contact-hero__status span {
      flex: 1 1 100%;
    }

    .contact-hero__diagram {
      min-height: 18rem;
    }

  }
</style>
