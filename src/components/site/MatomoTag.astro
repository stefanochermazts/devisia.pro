---
export interface Props {
  /** When true, Cookiebot holds the tag until statistics consent. */
  cookiebotEnabled?: boolean;
}

const { cookiebotEnabled = false } = Astro.props;

const trackerBase = import.meta.env.PUBLIC_MATOMO_URL || '//stat.devisia.it/';
const siteId = import.meta.env.PUBLIC_MATOMO_SITE_ID || '1';
---

<!-- Matomo -->
<script
  is:inline
  type={cookiebotEnabled ? 'text/plain' : undefined}
  data-cookieconsent={cookiebotEnabled ? 'statistics' : undefined}
  define:vars={{ trackerBase, siteId }}
>
  var _paq = (window._paq = window._paq || []);
  /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
  _paq.push(['trackPageView']);
  _paq.push(['enableLinkTracking']);
  (function () {
    var u = trackerBase;
    _paq.push(['setTrackerUrl', u + 'matomo.php']);
    _paq.push(['setSiteId', siteId]);
    var d = document,
      g = d.createElement('script'),
      s = d.getElementsByTagName('script')[0];
    g.async = true;
    g.src = u + 'matomo.js';
    s.parentNode.insertBefore(g, s);
  })();
</script>
<!-- End Matomo Code -->
