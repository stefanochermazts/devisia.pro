---
export interface Props {
  standalonePage?: boolean;
  lang?: 'it' | 'en';
}

const { standalonePage = false, lang = 'it' } = Astro.props;

const copy =
  lang === 'en'
    ? {
        pageTitle: 'Devisia assistant',
        pageLede:
          'Answers use the knowledge configured on the agent. Do not paste sensitive credentials or confidential data.',
        widgetTitle: 'Ask Devisia',
        widgetEyebrow: 'Knowledge-backed',
        statusLine: 'Perimeter-bound answers',
        close: 'Close',
        contact: 'Contact',
        fabLabel: 'Open assistant',
        conversationLabel: 'Conversation',
        chatWindowLabel: 'Chat window',
        messageLabel: 'Message',
        placeholder: 'Describe your question…',
        hint: 'Enter to send • Shift+Enter newline',
        send: 'Send',
      }
    : {
        pageTitle: 'Assistente Devisia',
        pageLede:
          'Risposte sulla base della knowledge configurata nell’agente. Non inviare dati sensibili o segreti.',
        widgetTitle: 'Parla con Devisia',
        widgetEyebrow: 'Assistenza contestuale',
        statusLine: 'Risposte in perimetro pubblico',
        close: 'Chiudi',
        contact: 'Contatti',
        fabLabel: 'Apri assistente',
        conversationLabel: 'Conversazione',
        chatWindowLabel: 'Finestra della chat',
        messageLabel: 'Messaggio',
        placeholder: 'Scrivi una domanda…',
        hint: 'Invio invia • Shift+Invio nuova riga',
        send: 'Invia',
      };

const panelId = standalonePage ? 'toolhouse-chat-panel-page' : 'toolhouse-chat-panel-widget';
const contactHref = lang === 'en' ? '/en/contact' : '/contatti';
---

{
  standalonePage ? (
    <div class="ds-chat" data-toolhouse-chat data-chat-layout="page">
      <header class="ds-chat-header ds-container">
        <h1 class="ds-chat-title">{copy.pageTitle}</h1>
        <p class="ds-chat-lede">{copy.pageLede}</p>
      </header>
      <section class="ds-chat-main" aria-label={copy.chatWindowLabel}>
        <div class="ds-chat-thread-wrap ds-container">
          <div class="ds-chat-thread" data-toolhouse-chat-thread role="log" aria-label={copy.conversationLabel} />
        </div>
        <p class="ds-chat-status ds-container" data-toolhouse-chat-status hidden aria-live="polite" />
        <div class="ds-chat-composer ds-container">
          <form class="ds-chat-form" data-toolhouse-chat-form>
            <label class="visually-hidden" for="toolhouse-chat-input">
              {copy.messageLabel}
            </label>
            <textarea
              id="toolhouse-chat-input"
              class="ds-chat-input"
              data-toolhouse-chat-input
              name="message"
              rows={3}
              maxlength={16000}
              placeholder={copy.placeholder}
              autocomplete="off"
              required
            />
            <div class="ds-chat-actions">
              <span class="ds-chat-hint">{copy.hint}</span>
              <button type="submit" class="ds-btn ds-chat-send" data-variant="primary" data-toolhouse-chat-send>
                {copy.send}
              </button>
            </div>
          </form>
        </div>
      </section>
    </div>
  ) : (
    <div class="ds-chat-widget-shell" data-toolhouse-chat data-chat-layout="widget">
      <div class="ds-chat-widget-backdrop" data-toolhouse-chat-backdrop hidden aria-hidden="true" />
      <div
        id={panelId}
        class="ds-chat-widget-panel"
        data-toolhouse-chat-panel
        role="dialog"
        aria-modal="true"
        aria-labelledby="toolhouse-chat-widget-heading"
        tabindex="-1"
        hidden
      >
        <header class="ds-chat-widget-top">
          <div class="ds-chat-widget-brand">
            <span class="ds-chat-widget-eyebrow">{copy.widgetEyebrow}</span>
            <h2 id="toolhouse-chat-widget-heading" class="ds-chat-widget-heading">
              {copy.widgetTitle}
            </h2>
          </div>
          <div class="ds-chat-widget-header-actions">
            <button
              type="button"
              class="ds-btn ds-chat-widget-close"
              data-variant="ghost"
              data-size="sm"
              data-toolhouse-chat-close
              aria-label={copy.close}
            >
              <span aria-hidden="true">✕</span>
              <span>{copy.close}</span>
            </button>
            <a class="ds-chat-widget-contact" href={contactHref}>{copy.contact}</a>
          </div>
        </header>

        <div class="ds-chat-widget-status-row">
          <span class="ds-chat-widget-live" aria-hidden="true" />
          <span>{copy.statusLine}</span>
        </div>

        <div class="ds-chat-widget-thread-wrap">
          <div
            class="ds-chat-thread ds-chat-widget-thread"
            data-toolhouse-chat-thread
            role="log"
            aria-label={copy.conversationLabel}
          />
          <p class="ds-chat-widget-status-strip" data-toolhouse-chat-status hidden aria-live="polite" />

          <div class="ds-chat-widget-composer">
            <form class="ds-chat-widget-form" data-toolhouse-chat-form novalidate>
              <label class="visually-hidden" for="toolhouse-widget-input">
                {copy.messageLabel}
              </label>
              <textarea
                id="toolhouse-widget-input"
                class="ds-chat-widget-input"
                data-toolhouse-chat-input
                name="message"
                rows={2}
                maxlength={16000}
                placeholder={copy.placeholder}
                autocomplete="off"
              />
              <div class="ds-chat-widget-actions">
                <span class="ds-chat-widget-hint">{copy.hint}</span>
                <button
                  type="submit"
                  class="ds-btn ds-chat-widget-send"
                  data-variant="primary"
                  data-toolhouse-chat-send
                >
                  {copy.send}
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <button
        type="button"
        class="ds-chat-widget-fab"
        data-toolhouse-chat-toggle
        aria-expanded="false"
        aria-controls={panelId}
        aria-label={copy.fabLabel}
      >
        <span class="ds-chat-widget-fab-glyph" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M12 3a7 7 0 013.6 13L12 21l-3.6-5A7 7 0 0112 3z"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linejoin="round"
            />
            <circle cx="9" cy="10" r="1.1" fill="currentColor" />
            <circle cx="12.2" cy="10" r="1.1" fill="currentColor" />
            <circle cx="15.4" cy="10" r="1.1" fill="currentColor" />
          </svg>
        </span>
        <span class="ds-chat-widget-fab-copy">
          <span class="ds-chat-widget-fab-title">{copy.widgetTitle}</span>
          <span class="ds-chat-widget-fab-micro">{copy.widgetEyebrow}</span>
        </span>
      </button>
    </div>
  )
}

<style>
  .ds-chat {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 8rem);
    padding-block: var(--ds-space-5) var(--ds-space-7);
    box-sizing: border-box;
    background: var(--ds-color-surface);
  }

  .ds-chat-header {
    margin-bottom: var(--ds-space-5);
    max-width: 52rem;
  }

  .ds-chat-title {
    font-family: var(--ds-font-heading);
    font-size: var(--ds-text-xl);
    font-weight: 800;
    margin: 0 0 var(--ds-space-2);
    letter-spacing: var(--ds-tracking-tight);
    color: var(--ds-color-text);
  }

  .ds-chat-lede {
    margin: 0;
    font-size: var(--ds-text-sm);
    color: var(--ds-color-text-muted);
    max-width: 56ch;
    line-height: var(--ds-leading-relaxed);
  }

  .ds-chat-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: min(72vh, 48rem);
  }

  .ds-chat-thread-wrap {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    max-width: 52rem;
    margin-inline: auto;
    width: 100%;
  }

  /** Widget shell */
  .ds-chat-widget-shell {
    pointer-events: none;
    isolation: isolate;
    /* Overlay globale: evita che hero/diagrammi o CTA sticky intercettino l'area del FAB. */
    position: fixed;
    inset: 0;
    z-index: 10000;
  }

  .ds-chat-widget-backdrop {
    pointer-events: auto;
    position: fixed;
    inset: 0;
    background: oklch(0.22 0.03 260 / 0.48);
    z-index: 1;
    opacity: 0;
    transition:
      opacity var(--ds-motion-base) var(--ds-ease-standard);
  }

  .ds-chat-widget-backdrop[hidden],
  .ds-chat-widget-panel[hidden] {
    display: none;
  }

  .ds-chat-widget-backdrop:not([hidden]) {
    opacity: 1;
  }

  .ds-chat-widget-panel {
    pointer-events: auto;
    position: fixed;
    z-index: 3;
    display: flex;
    flex-direction: column;
    background: linear-gradient(
      160deg,
      color-mix(in oklch, var(--ds-color-surface-2) 92%, transparent) 0%,
      var(--ds-color-bg) 45%,
      var(--ds-color-bg) 100%
    );
    border: var(--ds-border-1) solid color-mix(in oklch, var(--ds-color-accent-2) 28%, var(--ds-color-border));
    box-shadow: var(--ds-shadow-2),
      0 0 0 1px color-mix(in oklch, var(--ds-color-hero-tint) 18%, transparent);
    overflow: hidden;
    transform: translate3d(0, 14px, 0);
    opacity: 0;
    transition:
      transform var(--ds-motion-base) cubic-bezier(0.16, 1, 0.3, 1),
      opacity var(--ds-motion-fast) var(--ds-ease-standard);
  }

  .ds-chat-widget-panel:not([hidden]) {
    transform: translate3d(0, 0, 0);
    opacity: 1;
  }

  @media (min-width: 48rem) {
    .ds-chat-widget-panel {
      inset: auto;
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      right: max(1rem, env(safe-area-inset-right, 0px));
      width: min(460px, calc(100vw - 2rem));
      height: min(680px, calc(100dvh - 2rem));
      max-height: calc(100dvh - 2rem);
      border-radius: var(--ds-radius-4);
    }

    .ds-chat-widget-fab {
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      right: max(1rem, env(safe-area-inset-right, 0px));
    }

    .ds-chat-widget-shell:has(.ds-chat-widget-panel:not([hidden])) .ds-chat-widget-fab {
      opacity: 0;
      pointer-events: none;
      transform: translate3d(0, 24px, 0) scale(0.94);
      transition:
        opacity var(--ds-motion-fast) var(--ds-ease-standard),
        transform var(--ds-motion-base) cubic-bezier(0.16, 1, 0.3, 1);
    }
  }

  @media (max-width: 47.99rem) {
    .ds-chat-widget-panel {
      inset: 0;
      max-height: none;
      border-radius: 0;
      border: none;
      box-shadow: none;
    }

    .ds-chat-widget-fab {
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      right: calc(1rem + env(safe-area-inset-right, 0px));
    }
  }

  .ds-chat-widget-top {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-start;
    gap: var(--ds-space-2);
    padding: var(--ds-space-3) var(--ds-space-4) var(--ds-space-2);
    flex-shrink: 0;
    background: radial-gradient(
        140% 90% at 0% -20%,
        color-mix(in oklch, var(--ds-color-accent) 26%, transparent) 0,
        transparent 55%
      ),
      color-mix(in oklch, var(--ds-color-primary) 5%, transparent);
    border-bottom: var(--ds-border-1) solid color-mix(in oklch, var(--ds-color-accent-2) 22%, var(--ds-color-border));
  }

  :global(html[data-chat-widget-lock]) {
    overflow: hidden;
    overscroll-behavior-y: contain;
  }

  .ds-chat-widget-eyebrow {
    display: inline-block;
    font-family: var(--ds-font-ui);
    font-size: var(--ds-text-xs);
    font-weight: 700;
    letter-spacing: var(--ds-tracking-caps);
    text-transform: uppercase;
    color: color-mix(in oklch, var(--ds-color-accent) 92%, black);
    margin-bottom: var(--ds-space-1);
  }

  .ds-chat-widget-heading {
    font-family: var(--ds-font-heading);
    font-weight: 800;
    letter-spacing: var(--ds-tracking-tight);
    margin: 0;
    font-size: clamp(1.35rem, 1.16rem + 0.72vw, 1.68rem);
    line-height: var(--ds-leading-tight);
    max-width: 18ch;
  }

  .ds-chat-widget-header-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--ds-space-1);
  }

  .ds-chat-widget-close {
    font-family: var(--ds-font-ui) !important;
    font-weight: 700 !important;
    gap: var(--ds-space-2);
    border-radius: var(--ds-radius-round) !important;
  }

  .ds-chat-widget-contact {
    font-family: var(--ds-font-ui);
    font-size: var(--ds-text-xs);
    font-weight: 800;
    letter-spacing: 0.02em;
    color: color-mix(in oklch, var(--ds-color-accent) 82%, var(--ds-color-text));
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .ds-chat-widget-contact:focus-visible {
    outline: none;
    box-shadow: var(--ds-focus-ring);
    border-radius: var(--ds-radius-1);
  }

  .ds-chat-widget-status-row {
    display: flex;
    align-items: center;
    gap: var(--ds-space-2);
    flex-shrink: 0;
    padding: var(--ds-space-2) var(--ds-space-4);
    font-family: var(--ds-font-ui);
    font-size: var(--ds-text-xs);
    font-weight: 600;
    color: color-mix(in oklch, var(--ds-color-primary) 22%, var(--ds-color-text));
    letter-spacing: 0.02em;
  }

  .ds-chat-widget-live {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: var(--ds-radius-round);
    background: oklch(0.72 0.18 148);
    box-shadow:
      0 0 0 3px oklch(0.92 0.08 148 / 0.35),
      0 0 22px oklch(0.72 0.18 148 / 0.45);
    animation: ds-chat-widget-live 1.85s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  @keyframes ds-chat-widget-live {
    0% {
      opacity: 0.6;
      transform: scale(0.92);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0.55;
      transform: scale(0.92);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ds-chat-widget-live {
      animation: none;
      box-shadow: 0 0 0 2px oklch(0.85 0.06 148 / 0.5);
    }

    .ds-chat-widget-panel,
    .ds-chat-widget-backdrop,
    .ds-chat-widget-fab {
      transition-duration: var(--ds-motion-fast) !important;
    }
  }

  .ds-chat-widget-thread-wrap {
    flex: 1;
    min-height: 0;
    padding: var(--ds-space-2) var(--ds-space-3) var(--ds-space-3);
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-2);
    box-sizing: border-box;
    padding-bottom: max(var(--ds-space-3), env(safe-area-inset-bottom));
  }

  .ds-chat-widget-thread {
    flex: 1;
    min-height: 12rem;
    max-height: none;
    box-sizing: border-box;
    border-radius: var(--ds-radius-2);
    background: linear-gradient(
      to bottom,
      color-mix(in oklch, var(--ds-color-surface-2) 72%, transparent) 0%,
      transparent 96%
    );
  }

  .ds-chat-widget-thread.ds-chat-thread {
    padding: var(--ds-space-3);
    gap: var(--ds-space-3);
    font-size: clamp(0.94rem, 0.91rem + 0.14vw, 1rem);
    line-height: 1.58;
  }

  .ds-chat-widget-status-strip {
    margin: 0;
    font-size: var(--ds-text-xs);
    color: var(--ds-color-text-muted);
    font-family: var(--ds-font-ui);
    font-weight: 600;
  }

  .ds-chat-widget-composer {
    flex-shrink: 0;
    margin-top: 0;
    width: 100%;
  }

  .ds-chat-widget-form {
    display: flex;
    flex-direction: column;
    gap: var(--ds-space-2);
    padding: var(--ds-space-2);
    border-radius: var(--ds-radius-2);
    border: var(--ds-border-1) solid color-mix(in oklch, var(--ds-color-text) 14%, transparent);
    background: var(--ds-color-surface);
    box-shadow: var(--ds-shadow-1);
  }

  .ds-chat-widget-input {
    resize: vertical;
    min-height: 3.25rem;
    max-height: 7rem;
    font-family: var(--ds-font-sans);
    font-size: var(--ds-text-sm);
    line-height: 1.48;
    padding: var(--ds-space-2);
    border-radius: var(--ds-radius-2);
    border: var(--ds-border-1) solid color-mix(in oklch, var(--ds-color-text) 16%, transparent);
    background: var(--ds-color-bg);
    color: var(--ds-color-text);
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  .ds-chat-widget-input:focus-visible {
    box-shadow: var(--ds-focus-ring);
    border-color: color-mix(in oklch, var(--ds-color-accent) 55%, transparent);
  }

  .ds-chat-widget-input:disabled {
    opacity: 0.72;
    cursor: not-allowed;
  }

  .ds-chat-widget-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--ds-space-2);
  }

  .ds-chat-widget-hint {
    font-size: var(--ds-text-xs);
    color: var(--ds-color-text-muted);
    font-family: var(--ds-font-ui);
  }

  .ds-chat-widget-send.ds-btn {
    font-family: var(--ds-font-ui);
    border-radius: var(--ds-radius-round);
    min-height: 2.75rem;
    padding-inline: var(--ds-space-4);
    font-weight: 750 !important;
  }

  .ds-chat-widget-fab {
    pointer-events: auto;
    isolation: isolate;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--ds-space-2);
    position: fixed;
    z-index: 2;
    min-height: 3.05rem;
    width: fit-content;
    max-width: min(18rem, calc(100vw - 6rem));
    padding: var(--ds-space-2) var(--ds-space-4) var(--ds-space-2) var(--ds-space-3);
    border-radius: calc(var(--ds-radius-round) + 6px);
    border: var(--ds-border-1) solid color-mix(in oklch, var(--ds-color-surface) 78%, var(--ds-color-accent));
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    box-shadow:
      0 0 0 1px color-mix(in oklch, var(--ds-color-hero-tint) 72%, transparent),
      0 0 0 5px color-mix(in oklch, var(--ds-color-surface) 28%, transparent),
      0 18px 42px oklch(0.13 0.04 258 / 0.38),
      0 5px 14px oklch(0.22 0.04 255 / 0.22),
      inset 0 2px 0 oklch(1 0.01 270 / 0.16);
    color: oklch(0.975 0.02 265);
    background: radial-gradient(
        120% 120% at 12% -10%,
        color-mix(in oklch, var(--ds-color-accent) 44%, transparent) 0,
        transparent 48%
      ),
      linear-gradient(
        118deg,
        var(--ds-color-hero-tint),
        color-mix(in oklch, var(--ds-color-primary) 78%, var(--ds-color-hero-tint))
      );
    font-family: var(--ds-font-ui);
    transition:
      transform var(--ds-motion-base) cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow var(--ds-motion-base) var(--ds-ease-standard);
  }

  .ds-chat-widget-fab:focus-visible {
    outline: none;
    box-shadow:
      var(--ds-focus-ring),
      0 0 0 5px color-mix(in oklch, var(--ds-color-surface) 34%, transparent),
      0 18px 42px oklch(0.13 0.04 258 / 0.38),
      inset 0 2px 0 oklch(1 0.01 270 / 0.16);
  }

  .ds-chat-widget-fab:hover {
    transform: translateY(-4px);
    box-shadow:
      0 0 0 1px color-mix(in oklch, var(--ds-color-surface) 90%, transparent),
      0 0 0 6px color-mix(in oklch, var(--ds-color-accent) 22%, transparent),
      0 24px 54px oklch(0.12 0.05 258 / 0.44),
      inset 0 2px 0 oklch(1 0.01 270 / 0.18);
  }

  .ds-chat-widget-fab:active {
    transform: translateY(-1px);
    transition-duration: var(--ds-motion-fast);
  }

  .ds-chat-widget-fab-glyph svg {
    display: block;
  }

  .ds-chat-widget-fab-glyph {
    display: grid;
    place-items: center;
    width: 2.15rem;
    aspect-ratio: 1;
    border-radius: var(--ds-radius-round);
    background: color-mix(in oklch, var(--ds-color-surface) 92%, var(--ds-color-accent));
    color: color-mix(in oklch, var(--ds-color-hero-tint) 88%, var(--ds-color-primary));
    box-shadow:
      inset 0 0 0 1px color-mix(in oklch, var(--ds-color-surface) 80%, transparent),
      0 4px 12px oklch(0.16 0.04 258 / 0.24);
  }

  :global(:root[data-theme='dark']) .ds-chat-widget-fab-glyph {
    background: color-mix(in oklch, var(--ds-color-surface) 28%, var(--ds-color-text));
    color: color-mix(in oklch, var(--ds-color-hero-tint) 88%, var(--ds-color-primary));
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme])) .ds-chat-widget-fab-glyph {
      background: color-mix(in oklch, var(--ds-color-surface) 28%, var(--ds-color-text));
      color: color-mix(in oklch, var(--ds-color-hero-tint) 88%, var(--ds-color-primary));
    }
  }

  .ds-chat-widget-fab-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.06;
    min-width: 0;
    text-align: left;
  }

  .ds-chat-widget-fab-title {
    font-weight: 800;
    font-size: var(--ds-text-sm);
    letter-spacing: -0.02em;
  }

  .ds-chat-widget-fab-micro {
    font-size: clamp(0.68rem, 0.62rem + 0.35vw, 0.74rem);
    font-weight: 600;
    color: oklch(0.93 0.035 258);
    margin-top: 0.08rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 30rem) {
    .ds-chat-widget-fab {
      gap: var(--ds-space-1);
      grid-template-columns: auto;
      justify-items: center;
      padding: var(--ds-space-2);
