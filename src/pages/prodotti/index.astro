---
import Layout from '../../layouts/Layout.astro';
import PageIntro from '../../components/site/PageIntro.astro';
import ProductLane from '../../components/site/ProductLane.astro';
import EditorialCTA from '../../components/site/EditorialCTA.astro';
import { breadcrumbListJsonLd } from '../../lib/seo/structuredData';

const description =
  'Prodotti Devisia: piattaforme costruite quando un problema operativo mostra un pattern ripetibile. AuditReady per evidenze e compliance, Hooplytics per tornei e statistiche di basket.';

const site = Astro.site ?? new URL('https://devisia.pro');
const breadcrumbs = breadcrumbListJsonLd({
  site,
  items: [
    { name: 'Home', url: '/' },
    { name: 'Prodotti', url: '/prodotti' },
  ],
});
---

<Layout title="Prodotti Devisia: software e piattaforme governate" description={description} structuredData={[breadcrumbs]}>
  <PageIntro
    eyebrow="Prodotti"
    h1="Prodotti per trasformare controllo ed evidenze in operatività"
    lede="Costruiamo prodotti solo quando un problema operativo mostra un pattern ripetibile: controlli da mappare, evidenze da validare, responsabilità da rendere leggibili — o dati da gestire a bordocampo con controllo su cosa diventa pubblico."
  />

  <section class="products-catalog" aria-label="Catalogo prodotti Devisia">
    <ProductLane
      code="01"
      mark="PROOF"
      variant="proof"
      title="AuditReady"
      description="Sistema operativo per preparare prove: raccoglie richieste, collega controlli, valida responsabilità e produce pacchetti leggibili quando arriva un audit."
      href="/prodotti/auditready"
      status="Beta controllata"
      statusLines={['Evidence OS', 'DORA · NIS2']}
      tags={['compliance', 'audit', 'evidenze']}
      ctaLabel="Scopri AuditReady"
    />
    <ProductLane
      code="02"
      mark="COURT"
      variant="sport"
      title="Hooplytics"
      description="Piattaforma per gestire tornei, partite e statistiche di basket con pubblicazione controllata: chi gestisce decide cosa diventa pubblico."
      href="/prodotti/hooplytics"
      status="Progetto realizzato"
      statusLines={['Web + PWA', 'Offline-first']}
      tags={['basket', 'tornei', 'statistiche']}
        brandChips={[
          { name: 'Indigo', swatch: 'indigo' },
          { name: 'Arancio', swatch: 'orange' },
        ]}
      ctaLabel="Scopri Hooplytics"
    />
  </section>

  <aside class="product-future-note" aria-label="Criterio per futuri prodotti">
    Altri prodotti nasceranno solo quando un problema produce un pattern ripetibile: perimetro chiaro, controllo necessario, prova da mantenere.
  </aside>

  <EditorialCTA
    title="Il prodotto accelera solo se il perimetro è chiaro"
    ctaLabel="Parliamo di un prodotto verticale"
    ctaHref="/contatti"
    copy="Se avete in mente un dominio, un'evidenza ricorrente o un processo regolamentato, possiamo valutare se costruirlo o integrarlo. Senza forzare un prodotto dove serve prima lavoro di processo."
  />
</Layout>
