---
import Layout from '../../layouts/Layout.astro';
import PageIntro from '../../components/site/PageIntro.astro';
import WhatWeDoLayers from '../../components/site/WhatWeDoLayers.astro';
import EditorialCTA from '../../components/site/EditorialCTA.astro';
import { breadcrumbListJsonLd } from '../../lib/seo/structuredData';

const description =
  'Custom software development, web applications, SaaS, AI integration and automation for companies that need clearer, more efficient and controllable processes.';

const site = Astro.site ?? new URL('https://devisia.pro');
const breadcrumbs = breadcrumbListJsonLd({
  site,
  items: [
    { name: 'Home', url: '/en' },
    { name: 'What we do', url: '/en/what-we-do' },
  ],
});
---

<Layout
  lang="en"
  title="What we do"
  documentTitle="Custom software development, AI and SaaS | Devisia"
  description={description}
  structuredData={[breadcrumbs]}
>
  <PageIntro
    eyebrow="What we do"
    h1="Custom software, AI and automation to help your organisation work better"
    lede="We build platforms, web applications, SaaS products and AI integrations when a process is too important to stay manual, fragile or hard to control. We start from goals, people and existing systems, then turn work into useful, sustainable digital solutions."
  />

  <p class="sr-only">
    Visual summary: build applications and platforms, integrate data and systems, use AI and
    automation with control, continuity and verifiable results.
  </p>
  <section class="site-section site-section--dark what-we-do-layers">
    <section class="ds-container">
      <WhatWeDoLayers lang="en" />
    </section>
  </section>

  <section class="responsibility-filter" aria-labelledby="filter-title">
    <section>
      <p class="responsibility-filter__mark" aria-hidden="true">RESP</p>
      <section class="responsibility-filter__status" aria-hidden="true">
        <span>Threshold</span>
        <span>Control</span>
        <span>Proof</span>
      </section>
    </section>
    <section>
      <h2 id="filter-title" class="site-h2">
        We step in where software should simplify, not complicate
      </h2>
      <p class="site-lead">
        We are useful when a process involves several teams, sensitive data, tools that do not talk
        to each other or decisions that must stay clear. In those cases, code alone is not enough:
        you need method, integration and continuity after release.
      </p>
      <ul class="responsibility-filter__signals" aria-label="Signals of high-accountability work">
        <li>Slow or fragmented processes</li>
        <li>Tools that do not communicate</li>
        <li>Critical data, roles or approvals</li>
        <li>Need for continuity and control</li>
      </ul>
    </section>
  </section>

  <section class="evidence-chain-section" aria-labelledby="chain-title">
    <p class="evidence-chain-section__mark" aria-hidden="true">01-03</p>
    <section class="evidence-chain-section__intro">
      <h2 id="chain-title" class="site-h2">Before building, we make clear what needs to change</h2>
      <p class="site-lead">
        Every project starts from three simple questions. What slows the work down today? Which
        rules or responsibilities need to become explicit? How will we know, after release, that the
        solution is truly working?
      </p>
    </section>

    <ol class="evidence-chain" aria-label="Chain: real problem, right solution, measurable result">
      <li class="evidence-chain__item">
        <span class="evidence-chain__code" aria-hidden="true">01</span>
        <h3>Real problem</h3>
        <p>We identify where time, data, steps or ownership are being lost.</p>
      </li>
      <li class="evidence-chain__item">
        <span class="evidence-chain__code" aria-hidden="true">02</span>
        <h3>Right solution</h3>
        <p>
          We decide what to automate, what to integrate and what should remain under human
          supervision.
        </p>
      </li>
      <li class="evidence-chain__item">
        <span class="evidence-chain__code" aria-hidden="true">03</span>
        <h3>Measurable result</h3>
        <p>
          We define which signals show that the system works and can evolve without creating new
          chaos.
        </p>
      </li>
    </ol>
  </section>

  <section class="responsibility-matrix" aria-labelledby="matrix-title">
    <section class="responsibility-matrix__head">
      <h2 id="matrix-title" class="site-h2">What we build when the need is clear</h2>
      <p>
        We do not treat software, AI, integrations and compliance as separate worlds. We design them
        together, because a useful system should simplify work, connect tools and remain governable
        over time.
      </p>
    </section>

    <section class="responsibility-matrix__rows">
      <article class="responsibility-matrix__row">
        <span>Software</span>
        <h3>Web applications and platforms</h3>
        <p>
          Applications, portals and platforms for business processes that need more order, speed and
          continuity.
        </p>
        <section class="responsibility-matrix__proof">
          <strong>Expected value: less manual work, more control over the process.</strong>
        </section>
      </article>
      <article class="responsibility-matrix__row">
        <span>Integrations</span>
        <h3>Data, APIs and existing systems</h3>
        <p>
          We connect ERP, CRM, ticketing, Microsoft 365, SaaS and APIs so information does not stay
          trapped in silos.
        </p>
        <section class="responsibility-matrix__proof">
          <strong
            >Expected value: less copy-paste, fewer errors, better alignment between teams.</strong
          >
          <a class="ds-link" data-variant="muted" href="/en/sharepoint-microsoft-365-laravel"
            >SharePoint, Microsoft 365 and Laravel <span aria-hidden="true">→</span></a
          >
        </section>
      </article>
      <article class="responsibility-matrix__row">
        <span>AI</span>
        <h3>AI integration inside software</h3>
        <p>
          Assistants, RAG, agents and AI automation where they can truly help: search, synthesis,
          operational support and secondary checks.
        </p>
        <section class="responsibility-matrix__proof">
          <strong
            >Expected value: useful AI, with clear limits and human oversight where needed.</strong
          >
          <a class="ds-link" data-variant="muted" href="/en/governed-ai"
            >Explore governed AI <span aria-hidden="true">→</span></a
          >
        </section>
      </article>
      <article class="responsibility-matrix__row">
        <span>Compliance</span>
        <h3>Compliance, audit and operational tools</h3>
        <p>
          Dashboards, reports, control maps, assets and suppliers to make audits, security and
          operational responsibility easier to manage.
        </p>
        <section class="responsibility-matrix__proof">
          <strong
            >Expected value: information ready when needed, not rebuilt at the last minute.</strong
          >
          <a class="ds-link" data-variant="muted" href="/en/compliance-auditability"
            >Compliance and auditability <span aria-hidden="true">→</span></a
          >
        </section>
      </article>
    </section>
  </section>

  <section class="no-build-filter" aria-labelledby="no-build-title">
    <section class="no-build-filter__panel">
      <span aria-hidden="true">STOP</span>
      <h2 id="no-build-title">When we do not build</h2>
      <p>
        If the problem is not clear yet, if nobody can make decisions or if software would only hide
        a confused process, we prefer to stop and say so. Sometimes the first useful step is
        creating order, not writing code immediately.
      </p>
    </section>
  </section>

  <EditorialCTA
    variant="tint"
    title="Do you have a process, product or integration to evolve?"
    copy="Tell us what slows the work down today, which systems need to talk to each other and what results you want. We help you understand whether you need custom software, AI, automation or a combination that is easier to maintain."
    ctaLabel="Talk about the project"
    ctaHref="/en/contact"
  />
</Layout>
