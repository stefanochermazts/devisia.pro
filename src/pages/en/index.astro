---
import { AUDITREADY_SITE_URL } from '../../lib/auditready';
import Layout from '../../layouts/Layout.astro';
import SiteHero from '../../components/site/SiteHero.astro';
import SystemLayers from '../../components/site/SystemLayers.astro';
import EditorialCTA from '../../components/site/EditorialCTA.astro';
import { breadcrumbListJsonLd } from '../../lib/seo/structuredData';

const title = 'Home';
const description =
  'Software development company for custom software, AI for businesses and operational compliance: governable architecture, evidence and control over time.';

const site = Astro.site ?? new URL('https://devisia.pro');
const breadcrumbs = breadcrumbListJsonLd({
  site,
  items: [{ name: 'Home', url: '/en' }],
});
---

<Layout
  title={title}
  documentTitle="Devisia | Governed software, AI and compliance"
  description={description}
  structuredData={[breadcrumbs]}
  lang="en"
  containMain={false}
>
  <SiteHero
    title="Software that must hold when it has to be proven."
    lede="Devisia designs digital systems for organisations that cannot afford black boxes: platforms, governed AI and operational compliance where data, processes, accountability and evidence stay readable."
    primaryLabel="Talk about the system to build"
    primaryHref="/en/contact"
    secondaryLabel="See our method"
    secondaryHref="/en/method"
  >
    <section slot="visual" class="site-hero__viz">
      <section class="home-hero-signal" aria-hidden="true">
        <span>Process</span>
        <span>Control</span>
        <span>Proof</span>
      </section>
      <SystemLayers lang="en" />
    </section>
  </SiteHero>

  <section class="ds-container" style="padding-top:0">
    <section class="home-control-slab" aria-labelledby="home-prob">
      <p class="home-control-slab__word" aria-hidden="true">CTRL</p>
      <section>
        <h2 id="home-prob" class="site-h2">If the process is fragile, automation makes it faster</h2>
        <p class="site-lead">
          Technology does not rescue an opaque flow. When roles, data and constraints are explicit, custom software development and AI integration increase quality, control and operational capacity.
        </p>
      </section>
    </section>
  </section>

  <section class="site-section site-section--tint" aria-labelledby="home-three">
    <section class="ds-container">
      <h2 id="home-three" class="site-h2">Three domains, one governable system</h2>
      <p class="site-lead">
        We do not ship disconnected modules. A useful system connects custom software for businesses, governed AI and operational proof.
      </p>
      <section class="system-map">
        <p class="system-map__stamp" aria-hidden="true">01 / 02 / 03</p>
        <section class="system-map__track">
          <article class="system-map__item">
            <span class="system-map__num">01</span>
            <section>
              <h3>Custom software for businesses</h3>
              <p>Platforms and applications built to last, integrate with what you already run, and stay maintainable. Less guesswork, more decisions grounded in evidence.</p>
            </section>
          </article>
          <article class="system-map__item">
            <span class="system-map__num">02</span>
            <section>
              <h3>AI for businesses</h3>
              <p>Assistants, RAG, agents and workflows only where there is a control model: boundaries, logging, validation, human oversight and clear accountability.</p>
            </section>
          </article>
          <article class="system-map__item">
            <span class="system-map__num">03</span>
            <section>
              <h3>Operational compliance</h3>
              <p>Not a pile of policies, but the ongoing ability to show what was done, by whom, when and with which evidence.</p>
            </section>
          </article>
        </section>
      </section>
    </section>
  </section>

  <section class="ds-container">
    <section class="site-section" aria-labelledby="home-proof">
      <h2 id="home-proof" class="site-h2">From real work to verifiable proof</h2>
      <p class="site-lead">
        This is not a checklist. It is a chain of control: understand where risk begins, design the boundaries, and make each
        decision readable when it needs to be evidenced.
      </p>
      <section class="proof-rail">
        <article class="proof-rail__item">
          <section>
            <strong>Method</strong>
            <h3>Process before technology</h3>
            <p>We interview operators, exceptions and unwritten rules before choosing interfaces, automations or AI components.</p>
          </section>
          <a class="ds-link" data-variant="muted" href="/en/method">How we work <span aria-hidden="true">→</span></a>
        </article>
        <article class="proof-rail__item">
          <section>
            <strong>AI</strong>
            <h3>Models inside clear boundaries</h3>
            <p>A production AI system needs limits, logs, validation, policy, oversight and human accountability.</p>
          </section>
          <a class="ds-link" data-variant="muted" href="/en/governed-ai">Governed AI <span aria-hidden="true">→</span></a>
        </article>
        <article class="proof-rail__item">
          <section>
            <strong>Compliance</strong>
            <h3>Intentions are not evidence</h3>
            <p>GDPR, NIS2, DORA and ISO 27001 become sustainable when every control produces readable proof.</p>
          </section>
          <a class="ds-link" data-variant="muted" href="/en/compliance-auditability">Auditability <span aria-hidden="true">→</span></a>
        </article>
      </section>
    </section>
  </section>

  <section class="site-section site-section--dark" aria-labelledby="home-ar2">
    <section class="ds-container audit-console">
      <section>
        <h2 id="home-ar2" class="site-h2">AuditReady: when control becomes proof</h2>
        <p class="site-lead">
          Collect, organise, validate and export evidence for audits, compliance and security. AI-assisted where it helps, human
          control always. It is how we turn method and governance into an operational product.
        </p>
        <a
          class="ds-btn"
          data-variant="primary"
          data-size="lg"
          href={AUDITREADY_SITE_URL}
          target="_blank"
          rel="noopener noreferrer"
          style="margin-top: var(--ds-space-2)">Explore AuditReady</a>
      </section>
      <section class="audit-console__panel" aria-hidden="true">
        <section class="audit-console__header"><span>AuditReady</span><span>evidence stream</span></section>
        <section class="audit-console__row"><span>CTRL-01</span><span>Owner and data source assigned</span><span>logged</span></section>
        <section class="audit-console__row"><span>CTRL-02</span><span>Policy connected to the decision</span><span>checked</span></section>
        <section class="audit-console__row"><span>CTRL-03</span><span>Evidence export ready for audit</span><span>ready</span></section>
      </section>
    </section>
  </section>

  <section class="ds-container">
    <section class="site-section" aria-labelledby="home-why">
      <h2 id="home-why" class="site-h2">Less noise. More structure</h2>
      <ul class="site-list-check">
        <li>We start from process, not from a technology catalogue.</li>
        <li>We make constraints, data, roles and accountability explicit.</li>
        <li>We build readable, traceable software.</li>
        <li>We treat AI and compliance as architectural decisions, not add-ons.</li>
        <li>We favour controlled releases and verifiable evidence.</li>
      </ul>
    </section>
  </section>

  <EditorialCTA
    title="If the system must hold, we start from what it must prove"
    copy="Share process, data, risk, constraints and people involved. The first goal is to align context, boundaries and success criteria, not to sell a ready-made bundle."
    ctaLabel="Start a conversation"
    ctaHref="/en/contact"
  />
</Layout>
