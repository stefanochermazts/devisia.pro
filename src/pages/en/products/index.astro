---
import Layout from '../../../layouts/Layout.astro';
import PageIntro from '../../../components/site/PageIntro.astro';
import ProductLane from '../../../components/site/ProductLane.astro';
import EditorialCTA from '../../../components/site/EditorialCTA.astro';
import { breadcrumbListJsonLd } from '../../../lib/seo/structuredData';

const description =
  'Devisia products: platforms built when an operational problem reveals a repeatable pattern. AuditReady for evidence and compliance, Hooplytics for basketball tournaments and statistics.';

const site = Astro.site ?? new URL('https://devisia.pro');
const breadcrumbs = breadcrumbListJsonLd({
  site,
  items: [
    { name: 'Home', url: '/en' },
    { name: 'Products', url: '/en/products' },
  ],
});
---

<Layout lang="en" title="Devisia products: governed software platforms" description={description} structuredData={[breadcrumbs]}>
  <PageIntro
    eyebrow="Products"
    h1="Products that turn control and evidence into operations"
    lede="We build products only when an operational problem reveals a repeatable pattern: controls to map, evidence to validate, accountability to make readable — or data to manage courtside with control over what goes public."
  />

  <section class="products-catalog" aria-label="Devisia product catalog">
    <ProductLane
      code="01"
      mark="PROOF"
      variant="proof"
      title="AuditReady"
      description="An operating system for preparing proof: it gathers requests, connects controls, validates accountability and produces readable packs when an audit arrives."
      href="/en/products/auditready"
      status="Controlled beta"
      statusLines={['Evidence OS', 'DORA · NIS2']}
      tags={['compliance', 'audit', 'evidence']}
      ctaLabel="Explore AuditReady"
    />
    <ProductLane
      code="02"
      mark="COURT"
      variant="sport"
      title="Hooplytics"
      description="Platform to manage basketball tournaments, games and statistics with controlled publishing: whoever runs it decides what becomes public."
      href="/en/products/hooplytics"
      status="Delivered project"
      statusLines={['Web + PWA', 'Offline-first']}
      tags={['basketball', 'tournaments', 'statistics']}
        brandChips={[
          { name: 'Indigo', swatch: 'indigo' },
          { name: 'Orange', swatch: 'orange' },
        ]}
      ctaLabel="Explore Hooplytics"
    />
  </section>

  <aside class="product-future-note" aria-label="Criterion for future products">
    More products will appear only when a problem produces a repeatable pattern: clear perimeter, necessary control, proof to maintain.
  </aside>

  <EditorialCTA
    title="A product accelerates only when the perimeter is clear"
    ctaLabel="Talk about a vertical product"
    ctaHref="/en/contact"
    copy="If you have a domain, a recurring evidence need or a regulated process, we can see whether to build or integrate, without forcing product where process work must come first."
  />
</Layout>
