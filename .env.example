# Toolhouse Agents (server-only; used by /api/toolhouse-chat)
# Do not use PUBLIC_ — never expose the API key to the browser.
TOOLHOUSE_API_KEY=
TOOLHOUSE_AGENT_BASE=https://agents.toolhouse.ai/c5b9a9e9-a313-41e0-acb5-f2d610e2c190

# Google Ads conversion tag (gtag.js). Loaded after marketing cookie consent.
PUBLIC_GOOGLE_ADS_ID=AW-17995423794
# Google Ads lead form conversion (send_to label from Google Ads)
PUBLIC_GOOGLE_ADS_LEAD_CONVERSION=AW-17995423794/qpmdCJyIiZAcELLA8YRD

# LinkedIn Insight Tag (partner ID). Loaded after marketing cookie consent.
PUBLIC_LINKEDIN_PARTNER_ID=10089849

# Matomo analytics (head). Blocked by Cookiebot until statistics consent when PUBLIC_COOKIEBOT_ID is set.
PUBLIC_MATOMO_URL=//stat.devisia.it/
PUBLIC_MATOMO_SITE_ID=1
